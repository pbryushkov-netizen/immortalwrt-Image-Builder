#!/bin/sh /etc/rc.common
START=99
STOP=10
USE_PROCD=1
PROG=/usr/bin/vpn-runner.sh

start_service() {
    local enabled
    config_load vpn
    config_get enabled settings enabled 0
    [ "$enabled" = "1" ] || { logger -t "VPN" "Disabled"; return 0; }

    # Subscription is fetched synchronously inside vpn-runner.sh — no background race.
    procd_open_instance
    procd_set_param command "$PROG"
    # threshold=300s: allow time for binary+subscription download on first boot
    # timeout=10s: wait before restart; retry=5: max crash attempts
    procd_set_param respawn 300 10 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    killall sing-box 2>/dev/null
    ip link delete tun0 2>/dev/null
    rm -f /tmp/sing-box.json /tmp/sing-box-sub.json
}

reload_service() {
    stop_service
    sleep 1
    start_service
}
